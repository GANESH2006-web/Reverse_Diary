# Port for backend server
PORT=5000

# MongoDB Connection URI (local or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/micro-prompt-journal

# Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for signing JSON Web Tokens (JWT) for user sessions
JWT_SECRET=your_jwt_secret_key_here

# SMTP configuration for sending real verification emails (Optional fallback to console logging)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
